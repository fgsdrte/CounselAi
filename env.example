# ── Google Cloud ──────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# ── Vertex AI Vector Search ───────────────────────────────
VERTEX_INDEX_ID=projects/YOUR_PROJECT/locations/us-central1/indexes/YOUR_INDEX_ID
VERTEX_ENDPOINT_ID=projects/YOUR_PROJECT/locations/us-central1/indexEndpoints/YOUR_ENDPOINT_ID

# ── Cloud Storage ─────────────────────────────────────────
GCS_BUCKET=counselai-docs-bucket
GCS_RAW_PREFIX=raw/
GCS_METADATA_PREFIX=chunk_metadata/

# ── Gemini ────────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-pro

# ── Firebase Auth ─────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── App ───────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=20
